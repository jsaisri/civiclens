# ==========================
# Anthropic / Claude
# ==========================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-8

# ==========================
# Database (MySQL)
# ==========================
# Format: mysql+pymysql://username:password@host:port/database_name
# If your MySQL has no root password, leave it as: mysql+pymysql://root:@localhost:3306/civiclens
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/civiclens
DB_HOST=localhost
DB_PORT=3306
DB_NAME=civiclens
DB_USER=root
DB_PASSWORD=yourpassword

# ==========================
# Backend
# ==========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_here_change_in_production
DEBUG=true

# ==========================
# Frontend
# ==========================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=CivicLens

# ==========================
# File Uploads
# ==========================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls
